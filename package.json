{
  "name": "wertis-kolektor",
  "private": true,
  "version": "0.3.0",
  "description": "WERTIS — asystent magazyniera (Subiekt GT). Monorepo: server (Fastify/SQLite/worker) + android (kolektor Kotlin/Compose) + web/public (statyczny podgląd /lookup).",
  "workspaces": ["server"],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -n api,worker -c green,magenta \"npm:dev:api\" \"npm:dev:worker\"",
    "dev:api": "npm -w server run dev",
    "dev:worker": "npm -w server run worker",
    "seed": "npm -w server run seed",
    "import:mssql": "npm -w server run import:mssql",
    "build": "npm -w server run build",
    "start": "npm -w server run start"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
