{
  "name": "@wertis/server",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "description": "WERTIS — serwer API + worker Sfery (Fastify, SQLite).",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "worker": "tsx watch src/worker/worker.ts",
    "seed": "tsx src/db/seed.ts",
    "import:mssql": "tsx src/db/import-mssql.ts",
    "build": "tsc -p tsconfig.json && node -e \"require('fs').copyFileSync('src/db/schema.sql','dist/db/schema.sql')\"",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker/worker.js"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/static": "^8.0.4",
    "better-sqlite3": "^12.11.1",
    "fastify": "^5.2.1",
    "mssql": "^11.0.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/mssql": "^9.1.7",
    "@types/node": "^22.13.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
